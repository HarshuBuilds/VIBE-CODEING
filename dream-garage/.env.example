# Dream Garage Environment Variables

# Application Configuration
NEXT_PUBLIC_APP_NAME=Dream Garage
NEXT_PUBLIC_VERSION=1.0.0
NEXT_PUBLIC_DESCRIPTION=Explore your dream cars in an immersive 3D experience

# API Configuration (if using external API)
NEXT_PUBLIC_API_BASE_URL=https://api.dream-garage.com
NEXT_PUBLIC_API_TIMEOUT=10000

# Asset Configuration
NEXT_PUBLIC_ASSET_BASE_URL=/assets
NEXT_PUBLIC_MODEL_BASE_URL=/assets/models
NEXT_PUBLIC_TEXTURE_BASE_URL=/assets/textures
NEXT_PUBLIC_SOUND_BASE_URL=/assets/sounds
NEXT_PUBLIC_HDRI_BASE_URL=/assets/hdri

# Analytics Configuration (optional)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ANALYTICS_PROVIDER=google

# Performance Configuration
NEXT_PUBLIC_MAX_TEXTURE_SIZE=2048
NEXT_PUBLIC_MAX_MODELS=10
NEXT_PUBLIC_LOD_ENABLED=true
NEXT_PUBLIC_DRACO_COMPRESSION=true

# Feature Flags
NEXT_PUBLIC_ENABLE_SOUND=true
NEXT_PUBLIC_ENABLE_MUSIC=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=false

# Theme Configuration
NEXT_PUBLIC_DEFAULT_THEME=dark
NEXT_PUBLIC_DEFAULT_LIGHTING=studio
NEXT_PUBLIC_DEFAULT_VIEW_MODE=grid

# Social Media Configuration
NEXT_PUBLIC_SOCIAL_TWITTER=@dreamgarage
NEXT_PUBLIC_SOCIAL_FACEBOOK=dreamgarage
NEXT_PUBLIC_SOCIAL_INSTAGRAM=@dreamgarage
NEXT_PUBLIC_SOCIAL_LINKEDIN=dreamgarage

# Contact Configuration
NEXT_PUBLIC_CONTACT_EMAIL=contact@dream-garage.com
NEXT_PUBLIC_CONTACT_PHONE=+1-555-0123

# Legal Configuration
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy
NEXT_PUBLIC_TERMS_OF_SERVICE_URL=/terms
NEXT_PUBLIC_COOKIE_POLICY_URL=/cookies

# Maintenance Mode
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_MAINTENANCE_MESSAGE=We'll be back soon!

# Rate Limiting (for API routes)
NEXT_PUBLIC_RATE_LIMIT_ENABLED=false
NEXT_PUBLIC_RATE_LIMIT_WINDOW=60
NEXT_PUBLIC_RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration (for API routes)
NEXT_PUBLIC_CORS_ORIGINS=http://localhost:3000,https://dream-garage.vercel.app

# Database Configuration (if using database)
# DATABASE_URL=postgresql://user:password@localhost:5432/dream_garage
# DATABASE_PROVIDER=postgresql

# Authentication Configuration (if using auth)
# NEXT_PUBLIC_AUTH_PROVIDER=next-auth
# NEXT_PUBLIC_AUTH_SECRET=your-secret-key
# NEXT_PUBLIC_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
# NEXT_PUBLIC_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# NEXT_PUBLIC_AUTH_GITHUB_CLIENT_ID=your-github-client-id
# NEXT_PUBLIC_AUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Storage Configuration (if using cloud storage)
# NEXT_PUBLIC_STORAGE_PROVIDER=aws-s3
# NEXT_PUBLIC_AWS_ACCESS_KEY_ID=your-access-key
# NEXT_PUBLIC_AWS_SECRET_ACCESS_KEY=your-secret-key
# NEXT_PUBLIC_AWS_REGION=us-east-1
# NEXT_PUBLIC_AWS_S3_BUCKET=dream-garage-assets

# Email Configuration (if using email service)
# NEXT_PUBLIC_EMAIL_PROVIDER=sendgrid
# NEXT_PUBLIC_SENDGRID_API_KEY=your-sendgrid-api-key
# NEXT_PUBLIC_EMAIL_FROM=contact@dream-garage.com

# Payment Configuration (if using payments)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Note: All variables prefixed with NEXT_PUBLIC_ are exposed to the client-side
# Regular variables (without prefix) are only available server-side
